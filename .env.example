# ─── Resend (emails transactionnels) ───────────────────────
# Compte : https://resend.com
# RESEND_API_KEY=re_...
# RESEND_FROM="Starfobar × Ezéa <noreply@TON-DOMAINE.com>"
# ORDER_NOTIFY_TO=contact@ezea.fr          # optionnel : copie interne des commandes

# ─── Stripe Checkout + webhook ─────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...            # ou sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...          # endpoint → /api/stripe-webhook
# SITE_URL=https://starfobar.vercel.app    # optionnel

# ─── Brevo (optionnel — liste contacts newsletter) ─────────
# Si absent : l'email Resend part quand même, sans inscription liste.
# BREVO_API_KEY=xkeysib-...
# BREVO_LIST_ID=
